{
  "name": "exo",
  "bin": "./bin/exo",
  "systemHint": "Use the native `exo` internal tool to manage the current Exocortex daemon and spawn subagents. Keep this external `exo` CLI for debugging or targeting other daemon instances (for example with `exo --instance ...`). Run `exo -h` for CLI usage. Subagents start in Exocortex’s global default working directory, not the caller’s current directory; include the target absolute working directory in the task prompt when relevant.",
  "display": {
    "label": "Exocortex",
    "color": "#1d9bf0"
  },
  "shell": {
    "literalArgs": [
      {
        "subcommand": "send",
        "kind": "positional",
        "index": 0,
        "flagsWithValues": ["-c", "--conv", "--provider", "--model", "--instance", "--timeout", "--notify-parent", "--system"]
      },
      {
        "subcommand": "llm",
        "kind": "positional",
        "index": 0,
        "flagsWithValues": ["-c", "--conv", "--provider", "--model", "--instance", "--timeout", "--notify-parent", "--system"]
      },
      { "subcommand": "llm", "kind": "flag", "flag": "--system" },
      { "subcommand": "queue", "kind": "positional", "index": 1, "flagsWithValues": ["-c", "--conv", "--provider", "--model", "--instance", "--timeout", "--notify-parent", "--system"] },
      { "subcommand": "rename", "kind": "positional", "index": 1, "flagsWithValues": ["-c", "--conv", "--provider", "--model", "--instance", "--timeout", "--notify-parent", "--system"] }
    ]
  }
}
